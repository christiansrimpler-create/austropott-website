<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <meta name="description" content="{{ desc }}">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23e2001a'/%3E%3Ctext x='16' y='23' font-family='Courier, monospace' font-size='20' font-weight='bold' fill='%23fff' text-anchor='middle'%3EaP%3C/text%3E%3C/svg%3E">
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}?v={{ cssVersion }}">
</head>
<body>

  <header class="site-header">
    <div class="wrap">
      <a class="brand" href="{{ '/' | url }}">austro<img class="brand-p" src="{{ '/assets/img/austropott-p.png' | url }}" alt="P">ott<small>Theater im Dortmunder U</small></a>
      <nav class="main-nav" aria-label="Hauptnavigation">
        <ul>
          <li class="has-sub">
            <a href="{{ '/die-stuecke/index.html' | url }}"{% if active == "stuecke" %} aria-current="page"{% endif %}>Die Stücke</a>
            <ul class="sub">
              {%- for stueck in collections.stuecke %}
              <li><a href="{{ stueck.url | url }}">{{ stueck.data.titel }}</a></li>
              {%- endfor %}
            </ul>
          </li>
          <li><a href="{{ '/termine.html' | url }}"{% if active == "termine" %} aria-current="page"{% endif %}>Termine</a></li>
          <li><a href="{{ '/tickets.html' | url }}"{% if active == "tickets" %} aria-current="page"{% endif %}>Tickets</a></li>
          <li><a href="{{ '/team.html' | url }}"{% if active == "team" %} aria-current="page"{% endif %}>Team</a></li>
          <li class="has-sub">
            <a href="{{ '/service/index.html' | url }}"{% if active == "service" %} aria-current="page"{% endif %}>Service</a>
            <ul class="sub">
              <li><a href="{{ '/service/anfahrt.html' | url }}">Anfahrt</a></li>
              <li><a href="{{ '/service/das-u.html' | url }}">Das U</a></li>
              <li><a href="{{ '/service/newsletter.html' | url }}">Newsletter</a></li>
              <li><a href="{{ '/service/galerie.html' | url }}">Galerie</a></li>
              <li><a href="{{ '/service/archiv.html' | url }}">Archiv</a></li>
            </ul>
          </li>
          <li><a href="{{ '/kontakt.html' | url }}"{% if active == "kontakt" %} aria-current="page"{% endif %}>Kontakt</a></li>
        </ul>
        <a class="btn btn-red nav-ticket" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Tickets</a>
      </nav>
      <button class="burger" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-head">
      <a class="brand" href="{{ '/' | url }}">austro<img class="brand-p" src="{{ '/assets/img/austropott-p.png' | url }}" alt="P">ott<small>Theater im Dortmunder U</small></a>
      <button class="menu-close" aria-label="Menü schließen">✕</button>
    </div>
    <nav aria-label="Mobile Navigation">
      <ul>
        <li>
          <a href="{{ '/die-stuecke/index.html' | url }}"{% if active == "stuecke" %} aria-current="page"{% endif %}>Die Stücke</a>
          <ul class="sub-static">
            {%- for stueck in collections.stuecke %}
            <li><a href="{{ stueck.url | url }}">{{ stueck.data.titel }}</a></li>
            {%- endfor %}
          </ul>
        </li>
        <li><a href="{{ '/termine.html' | url }}"{% if active == "termine" %} aria-current="page"{% endif %}>Termine</a></li>
        <li><a href="{{ '/tickets.html' | url }}"{% if active == "tickets" %} aria-current="page"{% endif %}>Tickets</a></li>
        <li><a href="{{ '/team.html' | url }}"{% if active == "team" %} aria-current="page"{% endif %}>Team</a></li>
        <li>
          <a href="{{ '/service/index.html' | url }}"{% if active == "service" %} aria-current="page"{% endif %}>Service</a>
          <ul class="sub-static">
            <li><a href="{{ '/service/anfahrt.html' | url }}">Anfahrt</a></li>
            <li><a href="{{ '/service/das-u.html' | url }}">Das U</a></li>
            <li><a href="{{ '/service/newsletter.html' | url }}">Newsletter</a></li>
            <li><a href="{{ '/service/galerie.html' | url }}">Galerie</a></li>
            <li><a href="{{ '/service/archiv.html' | url }}">Archiv</a></li>
          </ul>
        </li>
        <li><a href="{{ '/kontakt.html' | url }}"{% if active == "kontakt" %} aria-current="page"{% endif %}>Kontakt</a></li>
      </ul>
    </nav>
    <div class="mobile-menu-foot">
      <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Tickets kaufen</a>
    </div>
  </div>

  <main>
{{ content | safe }}
  </main>

  <div class="ticket-bar">
    <span>Karten für alle Vorstellungen</span>
    <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Tickets</a>
  </div>

  <footer class="site-footer">
    <div class="wrap footer-main">
      <div class="footer-brand">
        <a class="brand" href="{{ '/' | url }}">austro<img class="brand-p" src="{{ '/assets/img/austropott-p.png' | url }}" alt="P">ott<small>Theater im Dortmunder U</small></a>
        <p>{{ einstellungen.footer_text }}</p>
        <div class="social">
          <a href="{{ einstellungen.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="17.3" cy="6.7" r="1.4"/></svg>
          </a>
          <a href="{{ einstellungen.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 21v-7h2.4l.4-3h-2.8V9.1c0-.9.3-1.5 1.6-1.5h1.3V5c-.2 0-1-.1-1.9-.1-1.9 0-3.2 1.2-3.2 3.3V11H9v3h2.3v7h2.2z"/></svg>
          </a>
          <a href="{{ einstellungen.youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2.5" y="6.5" width="19" height="12" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><polygon points="10.5,9.8 15.5,12.5 10.5,15.2"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h4>Theater</h4>
        <ul>
          <li><a href="{{ '/die-stuecke/index.html' | url }}">Die Stücke</a></li>
          <li><a href="{{ '/termine.html' | url }}">Termine</a></li>
          <li><a href="{{ '/tickets.html' | url }}">Tickets</a></li>
          <li><a href="{{ '/team.html' | url }}">Team</a></li>
          <li><a href="{{ '/service/archiv.html' | url }}">Archiv</a></li>
        </ul>
      </div>
      <div>
        <h4>Service</h4>
        <ul>
          <li><a href="{{ '/service/anfahrt.html' | url }}">Anfahrt</a></li>
          <li><a href="{{ '/service/das-u.html' | url }}">Das U</a></li>
          <li><a href="{{ '/service/newsletter.html' | url }}">Newsletter</a></li>
          <li><a href="{{ '/service/galerie.html' | url }}">Galerie</a></li>
          <li><a href="{{ '/kontakt.html' | url }}">Kontakt</a></li>
        </ul>
      </div>
      <div>
        <h4>Spielstätte</h4>
        <ul>
          <li>{{ einstellungen.spielstaette }}</li>
          <li>{{ einstellungen.adresse_strasse }}</li>
          <li>{{ einstellungen.adresse_ort }}</li>
          <li><a href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }}</a></li>
          <li><a href="mailto:{{ einstellungen.email }}">{{ einstellungen.email }}</a></li>
        </ul>
      </div>
    </div>
    <div class="wrap sponsoren">
      <h4>Wir danken unseren Sponsoren und Partnern</h4>
      <div class="sponsoren-logos">
        {%- for sponsor in einstellungen.sponsoren %}
        <span><img src="{{ sponsor.bild | url }}" alt="{{ sponsor.name }}" loading="lazy"></span>
        {%- endfor %}
      </div>
    </div>
    <div class="wrap footer-legal">
      <span>© {% year %} austroPott · Bujinski Kamp Schwaiger GbR</span>
      <a href="{{ '/impressum-und-datenschutz.html' | url }}">Impressum &amp; Datenschutz</a>
    </div>
  </footer>

  <script src="{{ '/assets/js/main.js' | url }}"></script>
</body>
</html>
