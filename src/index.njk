---
layout: layout.njk
permalink: /index.html
title: "austroPott – Theater im Dortmunder U | Theater mit Tiefgang in Dortmund"
desc: "austroPott spielt seit 2012 erfolgreiche Komödien und Schauspiele im Dortmunder U. Aktuelle Stücke: Einszweiundzwanzig vor dem Ende, Love Letters, Mephisto. Tickets online buchen."
active: start
---
    <section class="hero">
      {%- set startbild = einstellungen.hero_bild or '/assets/img/buehne-start.jpg' %}
      <div class="hero-slides">
        <img class="hero-bg is-active" src="{{ startbild | url }}" alt="Szene aus einer austroPott-Aufführung im Dortmunder U" fetchpriority="high" style="--fokus-d: {{ einstellungen.hero_fokus_desktop or '50% 35%' }}; --fokus-m: {{ einstellungen.hero_fokus_mobile or '58% center' }};">
        {%- for foto in alleFotos %}
        {%- if foto.bild != startbild %}
        <img class="hero-bg" data-src="{{ foto.bild | url }}" alt="" loading="lazy" style="--fokus-d: {{ foto.fokus_desktop or '50% 35%' }}; --fokus-m: {{ foto.fokus_mobile or '50% 35%' }};">
        {%- endif %}
        {%- endfor %}
      </div>
      <div class="wrap">
        <h1>{{ einstellungen.hero_headline }}</h1>
        <p class="lead">{{ einstellungen.hero_text }}</p>
        <div class="hero-actions">
          <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Tickets kaufen</a>
          <a class="btn btn-light" href="{{ '/termine/' | url }}">Zum Spielplan</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <div class="bigquote reveal">
          <blockquote>„{{ zitate.presse.text }}“</blockquote>
          <cite>{{ zitate.presse.quelle }}</cite>
        </div>
      </div>
    </section>

    <section class="section section-deep">
      <div class="wrap">
        <h2>{{ seiten.start.stuecke_ueberschrift }}</h2>
        <div class="stueck-grid">
          {%- for stueck in collections.stuecke %}
          <a class="stueck-card reveal" href="{{ stueck.url | url }}">
            <figure><img src="{{ stueck.data.bild | url }}" alt="{{ stueck.data.bild_alt }}" loading="lazy"></figure>
            <div class="genre">{{ stueck.data.genre }}</div>
            <h3>{{ stueck.data.titel }}</h3>
            <p>{{ stueck.data.kurztext }}</p>
            <span class="mehr">Mehr erfahren →</span>
          </a>
          {%- endfor %}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <h2>{{ seiten.start.termine_ueberschrift }}</h2>
        {%- set kommende = termine.termine | zukuenftige %}
        {%- if kommende.length %}
        <ul class="termin-liste" style="max-width:var(--w-text)">
          {%- for termin in kommende.slice(0, 4) %}
          {%- set ziel = termin.stueck | stueckUrl(collections.stuecke) %}
          <li class="termin">
            <span class="tag">{{ termin.datum | wochentag }}</span>
            <span class="zeit">{{ termin.uhrzeit }}</span>
            {%- if ziel %}
            <a class="titel" href="{{ ziel | url }}">{{ termin.stueck }}</a>
            {%- else %}
            <span class="titel">{{ termin.stueck }}</span>
            {%- endif %}
            <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Tickets</a>
          </li>
          {%- endfor %}
        </ul>
        <div class="hero-actions" style="margin-top:1.5rem">
          <a class="btn" href="{{ '/termine/' | url }}">Alle Termine</a>
        </div>
        {%- else %}
        <p class="lead prose">{{ einstellungen.termine_hinweis }} Abonnieren Sie unseren <a href="{{ '/service/newsletter/' | url }}">Newsletter</a>, damit Sie nichts verpassen – oder schauen Sie direkt im Ticketshop vorbei.</p>
        <div class="hero-actions">
          <a class="btn" href="{{ '/termine/' | url }}">Alle Termine</a>
          <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Zum Ticketshop</a>
        </div>
        {%- endif %}
      </div>
    </section>

    <section class="section section-night">
      <div class="wrap">
        <h2>{{ seiten.start.publikum_ueberschrift }}</h2>
        <div class="quote-grid">
          {%- for zitat in zitate.publikum %}
          <div class="quote-card reveal">
            <blockquote>„{{ zitat }}“</blockquote>
          </div>
          {%- endfor %}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="wrap kontakt-grid">
        <div>
          <h2>{{ seiten.start.ueber_ueberschrift }}</h2>
          <p class="lead">{{ seiten.start.ueber_lead }}</p>
          <p>{{ seiten.start.ueber_text }}</p>
          <a class="btn" href="{{ '/team/' | url }}">Das Team kennenlernen</a>
        </div>
        <figure class="frame" style="margin:0">
          <img src="{{ '/assets/img/galerie/siegersbusch-fim-6638.jpg' | url }}" alt="Michael Kamp auf der Bühne im Dortmunder U" loading="lazy">
        </figure>
      </div>
    </section>
