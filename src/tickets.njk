---
layout: layout.njk
permalink: /tickets/
title: "Tickets & Preise | austroPott – Theater im Dortmunder U"
desc: "Tickets für austroPott im Dortmunder U: Preise, Ermäßigungen, Abendkasse, Gutscheine. Karten online bei Tickettoaster buchen."
active: tickets
---
    <div class="wrap page-head">
      <h1>{{ seiten.tickets.ueberschrift }}</h1>
      <p class="lead">{{ seiten.tickets.lead }}</p>
      <div class="hero-actions" style="margin-bottom:2.5rem">
        <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Zum Ticketshop</a>
      </div>
    </div>
    <section class="section">
      <div class="wrap">
        <h2>{{ seiten.tickets.preise_ueberschrift }}</h2>
        <table class="preise">
          <thead>
            <tr><th>Kategorie</th><th>Plätze</th><th>Preis</th></tr>
          </thead>
          <tbody>
            {%- for kat in seiten.tickets.kategorien %}
            <tr><td class="kat">{{ kat.name }}</td><td>{{ kat.plaetze }}</td><td>{{ kat.preis }}</td></tr>
            {%- endfor %}
          </tbody>
        </table>
        <div class="prose">
          <p>{{ seiten.tickets.versand_hinweis }}</p>
          <p><strong>{{ seiten.tickets.ermaessigung_intro }}</strong></p>
          <ul>
            {%- for punkt in seiten.tickets.ermaessigung %}
            <li>{{ punkt }}</li>
            {%- endfor %}
          </ul>
        </div>
      </div>
    </section>
    <section class="section section-deep">
      <div class="wrap">
        <h2>{{ seiten.tickets.gutzuwissen_ueberschrift }}</h2>
        {%- for f in seiten.faq.fragen %}
        <details class="info"{% if loop.first %} open{% endif %}>
          <summary>{{ f.frage }}</summary>
          <div class="inhalt">{{ f.antwort | md | safe }}</div>
        </details>
        {%- endfor %}
        <div class="hero-actions" style="margin-top:2rem">
          <a class="btn btn-red" href="{{ einstellungen.ticket_url }}" target="_blank" rel="noopener">Zum Ticketshop</a>
          <a class="btn" href="{{ '/kontakt/' | url }}">Fragen? Kontaktieren Sie uns</a>
        </div>
      </div>
    </section>
